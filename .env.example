# 数据库路径（SQLite 本地文件）
DATABASE_URL="file:./data/sports-injury.db"

# NextAuth 配置（生产环境请用 openssl rand -hex 32 生成）
AUTH_SECRET="your-secret-here-change-me"

# 应用配置
NEXT_PUBLIC_APP_NAME="运动损伤资料管理与指标分析平台"

# Supabase 配置（生产环境使用 Supabase PostgreSQL）
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxx"
SUPABASE_SERVICE_ROLE_KEY="sb_secret_xxx"
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="sports-injury-files"

# DeepSeek API（数据分析用）
DEEPSEEK_API_KEY="sk-xxx"

# 冒烟测试 — 设置后登录流程测试（2个case）会被覆盖
SMOKE_TEST_EMAIL="test@example.com"
SMOKE_TEST_PASSWORD="your-test-password"
# 通知 Webhook — CI/冒烟/自动修复结果推送到 IM
# 飞书示例: https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# 钉钉示例: https://oapi.dingtalk.com/robot/send?access_token=xxx
# Slack 示例: https://hooks.slack.com/services/xxx
NOTIFY_WEBHOOK=""