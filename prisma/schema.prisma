// Prisma Schema 鈥?杩愬姩鎹熶激璧勬枡绠＄悊涓庢寚鏍囧垎鏋愬钩鍙?
// 鏁版嵁搴? PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== 鐢ㄦ埛涓庢潈闄?====================

model User {
  id                String    @id @default(cuid())
  username          String    @unique
  email             String?   @unique
  supabaseUserId    String?   @unique
  password          String    // bcrypt hash
  role              Role      @default(VISITOR)
  passwordChangedAt DateTime? // null = 浠庢湭淇敼杩囧瘑鐮?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  files             File[]
  analyses          AnalysisRecord[]
  auditLogs         AuditLog[]
}

enum Role {
  VISITOR    // 娓稿锛堝彧璇伙級
  ADMIN      // 绠＄悊鍛橈紙鍙紪杈戞枃浠?鎸囨爣锛?
  SUPERADMIN // 瓒呯骇绠＄悊鍛橈紙鍙鐞嗙敤鎴凤級
}

// ==================== 鏂囦欢澶癸紙鏍戠姸缁撴瀯锛?====================

model Folder {
  id        String     @id @default(cuid())
  name      String
  parentId  String?
  parent    Folder?    @relation("FolderTree", fields: [parentId], references: [id])
  children  Folder[]   @relation("FolderTree")
  sortOrder Int        @default(0)
  type      FolderType
  files     File[]
  createdAt DateTime   @default(now())
}

enum FolderType {
  INJURY     // 杩愬姩鎹熶激璧勬枡
  INDICATOR  // 鎸囨爣浣撶郴
  ANALYSIS   // 鏁版嵁鍒嗘瀽
}

// ==================== 鏂囦欢 ====================

model File {
  id           String    @id @default(cuid())
  name         String
  originalName String
  path         String
  size         Int
  mimeType     String
  tags         String    @default("") // JSON array
  folderId     String
  folder       Folder    @relation(fields: [folderId], references: [id])
  uploadedBy   String
  uploader     User      @relation(fields: [uploadedBy], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? // 杞垹闄?
}

// ==================== 鎸囨爣浣撶郴 ====================

model IndicatorCategory {
  id          String      @id @default(cuid())
  name        String      @unique // 鍔涢噺/骞宠　/鏌旈煣鎬?鐖嗗彂鍔?鍏宠妭娲诲姩搴?姝ユ€?鐤肩棝璇勫垎
  description String?
  indicators  Indicator[]
  createdAt   DateTime    @default(now())
}

model Indicator {
  id            String         @id @default(cuid())
  name          String         // 鎸囨爣鍚嶇О锛屽 ACL_LSI, YBT, ROM
  description   String?
  unit          String         // 鍗曚綅锛屽 % / cm / 掳 / 鍒?
  normalRange   String         // 姝ｅ父鑼冨洿
  riskThreshold String?        // 椋庨櫓闃堝€?
  testMethod    String?        // 娴嬭瘯鏂规硶
  dataSource    String?        // 鏁版嵁鏉ユ簮
  categoryId    String
  category      IndicatorCategory @relation(fields: [categoryId], references: [id])
  excelMappings ExcelMapping[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
}

model ExcelMapping {
  id          String    @id @default(cuid())
  columnName  String    // Excel 鍒楀悕
  indicatorId String
  indicator   Indicator @relation(fields: [indicatorId], references: [id])
  sheetName   String?
  createdAt   DateTime  @default(now())
}

model ExcelFile {
  id         String   @id @default(cuid())
  name       String
  path       String
  sheetCount Int
  uploadedBy String
  createdAt  DateTime @default(now())
}

// ==================== 鍒嗘瀽璁板綍 ====================

model AnalysisRecord {
  id        String       @id @default(cuid())
  type      AnalysisType
  config    String       // JSON config
  result    String       // JSON result
  createdBy String
  user      User         @relation(fields: [createdBy], references: [id])
  createdAt DateTime     @default(now())
}

enum AnalysisType {
  DESCRIPTIVE   // 鎻忚堪缁熻
  CORRELATION   // 鐩稿叧鎬у垎鏋?
  TREND         // 瓒嬪娍鍒嗘瀽
}

// ==================== 鎿嶄綔瀹¤鏃ュ織 ====================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // UPLOAD / DELETE / MODIFY / CREATE / LOGIN / EXPORT
  target    String   // 鎿嶄綔瀵硅薄绫诲瀷锛欶ILE / INDICATOR / USER / SYSTEM
  targetId  String?  // 鎿嶄綔瀵硅薄 ID
  detail    String?  // 鎿嶄綔璇︽儏
  createdAt DateTime @default(now())
}

